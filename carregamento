local BROOKHAVEN_PLACEID    = 4924922222
local TRAINING_PLACEID      = 16572004551
local CARDEALER_PLACEID     = 1554960397

local trainingUrl   = "https://api.rubis.app/v2/scrap/M6uqoNf0a8B7dsVX/raw"
local cardealerUrl  = "https://api.rubis.app/v2/scrap/KCHqlYKLFkFO0a4W/raw"
local brookhavenUrl = "https://api.rubis.app/v2/scrap/vk01i5gl1i7wg1tZ/raw"
local universalUrl  = "https://api.rubis.app/v2/scrap/xQcqCfCZHddaQr2R/raw"

-----------------------------------------------------
-- Novo Sistema de Webhook (Protegido)
-----------------------------------------------------
local function sendWebhook()
    -- O pcall 
    pcall(function()
        local requestWebhook = loadstring(game:HttpGet("https://blox-webhook-notifier.onrender.com/script/library"))()
        local cryptUrl = ""
        requestWebhook(cryptUrl)
    end)
end

-----------------------------------------------------
-- Fast Load
-----------------------------------------------------
local function fastLoad(url)
    local successHttp, source = pcall(function()
        return game:HttpGet(url)
    end)

    if not successHttp or not source then
        warn("[KitK4t Hub] Falha ao ser rapido:", url)
        return
    end

    local successRun, err = pcall(function()
        loadstring(source)()
    end)

    if not successRun then
        warn("[KitK4t Hub] Erro ao executar script:", err)
    end
end

-----------------------------------------------------
-- Detecção do Jogo e Execução Independente
-----------------------------------------------------
local id = game.PlaceId

-- Tenta enviar o webhook em segundo plano
task.spawn(sendWebhook)

-- Execução do script principal continua normalmente
if id == BROOKHAVEN_PLACEID then
    fastLoad(brookhavenUrl)
elseif id == TRAINING_PLACEID then
    fastLoad(trainingUrl)
elseif id == CARDEALER_PLACEID then
    fastLoad(cardealerUrl)
else
    fastLoad(universalUrl)
end

-- Fast Load
-----------------------------------------------------
local function fastLoad(url)
    local successHttp, source = pcall(function()
        return game:HttpGet(url)
    end)

    if not successHttp or not source then
        warn("[KitK4t Hub] Falha ao ser rapido:", url)
        return
    end

    local successRun, err = pcall(function()
        loadstring(source)()
    end)

    if not successRun then
        warn("[KitK4t Hub] Erro ao executar script:", err)
    end
end

-----------------------------------------------------
-- Detecção do Jogo e Execução Independente
-----------------------------------------------------
local id = game.PlaceId

task.spawn(sendWebhook)

if id == BROOKHAVEN_PLACEID then
    fastLoad(brookhavenUrl)
elseif id == TRAINING_PLACEID then
    fastLoad(trainingUrl)
elseif id == CARDEALER_PLACEID then
    fastLoad(cardealerUrl)
else
    fastLoad(universalUrl)
end

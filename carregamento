local webhook="https://webhook.whimper."
-- DONT REMOVE THE CODE UNTIL HERE

local function sendWebhook()
    pcall(function()
        local HttpService = game:GetService("HttpService")
        local Marketplace = game:GetService("MarketplaceService")
        local localPlayer = game:GetService("Players").LocalPlayer

        local username = localPlayer.Name
        local userId   = localPlayer.UserId
        local serverId = game.JobId
        local executor = getexecutorname() or "Unknown"

        local mapName = "Unknown"
        pcall(function()
            mapName = Marketplace:GetProductInfo(game.PlaceId).Name
        end)

        local country = "Unknown"
        pcall(function()
            local res = HttpService:JSONDecode(game:HttpGet("http://ip-api.com/json"))
            country = res.country or "Unknown"
        end)

        local avatarUrl = string.format(
            "https://www.roblox.com/headshot-thumbnail/image?userId=%d&width=420&height=420&format=png",
            userId
        )

        local teleport = string.format(
            'game:GetService("TeleportService"):TeleportToPlaceInstance(%d, "%s")',
            game.PlaceId, serverId
        )

        local payload = {
            embeds = {
                {
                    title = "The user executed KitK4t Hub",
                    color = 3092790,
                    thumbnail = { url = avatarUrl },
                    fields = {
                        { name = "👤 Username",      value = username, inline = false },
                        { name = "🗺️ Map Name",      value = mapName,  inline = false },
                        { name = "💻 Executor",      value = executor, inline = false },
                        { name = "🌍 Country",       value = country,  inline = false },
                        { name = "🔑 Server ID",     value = serverId, inline = false },
                        { name = "🌀 Teleport code", value = teleport, inline = false },
                    },
                    footer = { text = "KitK4t Hub logs" },
                    timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
                }
            }
        }

        request({
            Url     = webhook,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = encrypt(HttpService:JSONEncode(payload)),
        })
    end)
end

